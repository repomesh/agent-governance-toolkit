{
  "$schema": "../cases.schema.json",
  "id": "spec-16-effects.case-03",
  "spec_section": "16",
  "title": "AGT D1: dispatcher output with replace effects targeting snapshot is rejected",
  "claimable": true,
  "operation": "evaluate",
  "sdk_support": {
    "rust": "required",
    "python": "required",
    "node": "required",
    "dotnet": "optional"
  },
  "manifest_yaml": "agent_control_specification_version: 0.3.1-beta\npolicies:\n  p:\n    type: rego\n    query: data.acs.verdict\nintervention_points:\n  input:\n    policy:\n      id: p\n    policy_target: $snap.input\n",
  "intervention_point": "input",
  "snapshot": {
    "input": {
      "text": "secret"
    }
  },
  "policy_response": {
    "decision": "allow",
    "effects": [
      {
        "type": "replace",
        "path": "$snap.input.text",
        "value": "leak"
      }
    ]
  },
  "expected": {
    "decision": "deny",
    "reason": "runtime_error:policy_output_invalid",
    "transformed_policy_target": null
  }
}
