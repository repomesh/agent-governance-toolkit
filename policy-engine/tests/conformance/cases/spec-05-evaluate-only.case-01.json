{
  "$schema": "../cases.schema.json",
  "id": "spec-05-evaluate-only.case-01",
  "spec_section": "5",
  "title": "evaluate_only validates transform without applying it",
  "claimable": true,
  "operation": "evaluate",
  "sdk_support": {
    "rust": "required",
    "python": "required",
    "node": "required",
    "dotnet": "optional"
  },
  "manifest_yaml": "agent_control_specification_version: 0.3.1-beta\npolicies:\n  p:\n    type: rego\n    query: data.acs.verdict\nintervention_points:\n  input:\n    policy:\n      id: p\n    policy_target: $snap.input\n",
  "intervention_point": "input",
  "mode": "evaluate_only",
  "snapshot": {
    "input": {
      "text": "secret account number 1234"
    }
  },
  "policy_response": {
    "decision": "transform",
    "reason": "pii_redaction",
    "transform": {
      "path": "$policy_target.text",
      "value": "secret account number [REDACTED]"
    }
  },
  "expected": {
    "decision": "transform",
    "reason": "pii_redaction",
    "transformed_policy_target": null,
    "action_identity": "present"
  }
}
